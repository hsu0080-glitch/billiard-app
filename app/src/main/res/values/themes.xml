<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Theme.BilliardNearby" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary_variant</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/primary_dark</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background_light</item>
    </style>

    <!-- NoActionBar variant for activities that manage their own toolbar -->
    <style name="Theme.BilliardNearby.NoActionBar" parent="Theme.BilliardNearby">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash / Main screen theme (dark background) -->
    <style name="Theme.BilliardNearby.Main" parent="Theme.BilliardNearby.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/background_dark</item>
    </style>

</resources>
